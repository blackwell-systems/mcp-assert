        "phpunit/phpunit": "^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "BlackwellSystems\\McpAssert\\": "src/"
        }
    },
    "homepage": "https://github.com/blackwell-systems/phpunit-mcp-assert",
    "support": {
        "issues": "https://github.com/blackwell-systems/phpunit-mcp-assert/issues",
